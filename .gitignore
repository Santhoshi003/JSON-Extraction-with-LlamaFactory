# .gitignore for Llama JSON Extraction Project

# Do NOT commit large model files
*.bin
*.safetensors
*.pt
*.pth

# Do NOT commit LoRA adapter weights
adapter_model.bin
adapter_config.json

# Do NOT commit checkpoint directories (intermediate training states)
checkpoint-*/
runs/

# Python virtual environments
venv/
.venv/
env/
.env

# Cache and build artifacts
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Jupyter Notebook
.ipynb_checkpoints/
*.ipynb

# LlamaFactory cache
.cache/
cache/

# Datasets (if large; download on demand)
# datasets/
# *.arrow
# *.parquet

# Model downloads (download on demand)
# models/

# Local experimental files
*.tmp
*.log
debug/

# Screenshots and sensitive info
# (Keep screenshots/ since they're part of deliverables)
